    {
      "id": "contracts",
      "name": "Smart Contracts",
      "description": "On-chain insurance protocol: SurelyFactory, InsurancePool, PolicyNFT, CZUSD, CRERouter, EligibilityRegistry, ComplianceConsumer + ACE policy framework (PolicyEngine, 6 policies, UnifiedExtractor)",
      "color": "#f97316",
      "icon": "FileCode",
      "counts": {
        "screens": 0,
        "endpoints": 0,
        "tables": 16,
        "implemented": 16,
