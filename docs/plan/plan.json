          }
        ]
      }
    ],
    "externalAPIs": [
      {
        "name": "Claude Service",
        "baseUrl": "env:CLAUDE_SERVICE_URL",
        "auth": "X-API-Key header",
        "purpose": "AI insurance advisor (sync chat)"
      },
      {
        "name": "Stripe",
        "baseUrl": "https://api.stripe.com",
        "auth": "STRIPE_SECRET_KEY",
        "purpose": "Fiat payment for CZUSD purchase"
      },
      {
        "name": "Mock Server",
        "baseUrl": "env:MOCK_SERVER_URL (default: http://localhost:4000)",
        "auth": "none",
        "purpose": "Test data source for trigger configuration (BTC price, weather, flight status)"
      }
    ],
    "aiServices": [
      {
        "name": "Claude Service (Sonnet)",
        "provider": "Anthropic via Claude Service proxy",
        "purpose": "Insurance advisor: answers user questions about specific policies",
        "model": "sonnet"
      }
    ],
    "sharedServices": [
      {
        "name": "Thirdweb Connect",
        "purpose": "Wallet auth (email/social/WalletConnect), contract reads via ThirdwebProvider"
      },
      {
        "name": "Server Wallet (PRIVATE_KEY)",
        "purpose": "Activates pools and stores eligibility proofs on-chain — server-side only"
      }
    ]
  },
