  "flows": [
    {
      "id": "browse-pools",
      "name": "User Browses Insurance Pools",
      "trigger": "navigation",
      "priority": "critical",
      "module": "pools",
      "outcome": "User sees all active insurance pools in grid or table view",
      "tags": ["pools", "browse", "search"],
      "steps": [
        {
          "order": 1,
          "screen": "pools.list",
          "description": "User navigates to /policies",
          "checks": ["Pool grid renders", "Loading state shown while fetching"]
        },
        {
          "order": 2,
          "screen": "pools.list",
          "description": "useAllPools() reads factory.getPoolAddresses() on-chain, renders pool cards",
          "pipelineRef": "forge-contracts",
          "checks": ["Pool cards show name, type badge, state, premium, payout"]
        },
        {
          "order": 3,
          "screen": "pools.list",
          "description": "User can search by name, filter by type (crypto/stablecoin/weather/flight), switch grid/table",
          "checks": [
            "Search filters pool cards",
            "Type filter works",
            "Table view shows columns"
          ]
        }
      ]
    },
    {
      "id": "view-pool-detail",
      "name": "User Views Pool Detail",
      "trigger": "navigation",
      "priority": "critical",
      "module": "pool-detail",
      "outcome": "User sees full pool parameters, monitoring chart, agreements, and can ask AI advisor",
      "tags": ["pool-detail", "ai-advisor", "monitoring"],
      "steps": [
        {
          "order": 1,
          "screen": "pool-detail.detail",
          "description": "User clicks pool card or navigates to /policies/[address]",
          "pipelineRef": "forge-contracts",
          "checks": ["Pool name, state badge, and params load from chain"]
        },
        {
          "order": 2,
          "screen": "pool-detail.detail",
          "description": "Monitoring chart shows mock time-series for the trigger metric",
          "checks": [
            "Chart renders with threshold line",
            "Candlestick or line mode"
          ]
        },
        {
          "order": 3,
          "screen": "pool-detail.detail",
          "description": "User views Agreements tab with eligibility and settlement agreement text",
          "checks": ["AgreementViewer renders both agreement texts"]
        },
        {
          "order": 4,
          "screen": "pool-detail.detail",
          "description": "User types question in AI advisor, clicks Ask",
          "endpoint": "pool-detail.ai-chat",
          "pipelineRef": "api-endpoints",
          "checks": [
            "POST /api/ai-chat called with prompt + context",
            "Response text shown"
          ]
        }
      ]
    },
    {
      "id": "create-pool",
      "name": "Creator Deploys Insurance Pool",
      "trigger": "user_action",
      "priority": "critical",
      "module": "create",
      "outcome": "New InsurancePool deployed on Avalanche Fuji via SurelyFactory, pool activated by server wallet",
      "tags": ["create", "deploy", "factory", "wizard"],
      "steps": [
        {
          "order": 1,
          "screen": "create.wizard",
          "description": "Creator selects 2-3 data sources (e.g. CoinGecko, CryptoCompare, Chainlink) and consensus method",
          "checks": ["Source cards selectable", "Consensus method toggle works"]
        },
        {
          "order": 2,
          "screen": "create.wizard",
          "description": "Creator configures trigger: metric, comparison (gt/lt/gte/lte), threshold, duration, cadence",
          "endpoint": "create.test-source",
          "pipelineRef": "api-endpoints",
          "checks": [
            "All fields validated before Next",
            "Test source fetches live data"
          ]
        },
        {
          "order": 3,
          "screen": "create.wizard",
          "description": "Creator writes eligibility and settlement agreement text, selects verification type",
          "endpoint": "pool-detail.ai-chat",
          "pipelineRef": "api-endpoints",
          "checks": [
            "AI generation available for agreement text",
            "Both agreements non-empty"
          ]
        },
        {
          "order": 4,
          "screen": "create.wizard",
          "description": "Creator sets premium, maxPayout, duration, min/max policyholders, deposits CZUSD underwriting capital",
          "pipelineRef": "forge-contracts",
          "checks": [
            "Deposit amount > 0",
            "Connected wallet signs createPool() tx"
          ]
        },
        {
          "order": 5,
          "endpoint": "create.activate-pool",
          "description": "POST /api/activate-pool with txHash — server wallet calls factory.activatePool()",
          "pipelineRef": "api-endpoints",
          "checks": ["Pool state transitions from FUNDING to ACTIVE"]
        },
        {
          "order": 6,
          "screen": "create.wizard",
          "description": "Success — user redirected to /policies/[newPoolAddress]",
          "checks": ["New pool appears in pool list"]
        }
      ]
    },
    {
      "id": "acquire-policy",
      "name": "User Acquires Insurance Policy",
      "trigger": "user_action",
      "priority": "critical",
      "module": "acquire",
      "outcome": "Policy NFT minted to user's wallet via InsurancePool.purchasePolicy()",
      "tags": ["acquire", "policy", "eligibility", "payment"],
      "steps": [
        {
          "order": 1,
          "screen": "acquire.flow",
          "description": "User navigates to /policies/[address]/acquire, sees Eligibility step",
          "pipelineRef": "forge-contracts",
          "checks": [
            "Pool name loaded",
            "Verification type shown (none/identity/flight/employment/property)"
          ]
        },
        {
          "order": 2,
          "endpoint": "acquire.eligibility",
          "description": "User fills eligibility form, POST /api/eligibility — server generates proofHash, stores on EligibilityRegistry",
          "pipelineRef": "api-endpoints",
          "checks": [
            "proofHash returned",
            "Proof stored on-chain if PRIVATE_KEY set"
          ]
        },
        {
          "order": 3,
          "screen": "acquire.flow",
          "description": "Payment step: user selects CZUSD (on-chain) or Stripe (fiat→CZUSD)",
          "pipelineRef": "forge-contracts",
          "checks": [
            "CZUSD balance shown",
            "Stripe payment form renders if fiat selected"
          ]
        },
        {
          "order": 4,
          "screen": "acquire.flow",
          "description": "Confirm step: user reviews coverage details, clicks Confirm",
          "pipelineRef": "forge-contracts",
          "checks": [
            "Gas pre-check passes (ETH balance > 0)",
            "purchasePolicy() tx signed"
          ]
        },
        {
          "order": 5,
          "screen": "acquire.flow",
          "description": "PolicyNFT minted — success state with txHash link",
          "pipelineRef": "forge-contracts",
          "checks": ["Confirmed = true", "Link to /coverage"]
        }
      ]
    },
    {
      "id": "view-coverage",
      "name": "User Views Their Policies",
      "trigger": "navigation",
      "priority": "high",
      "module": "coverage",
      "outcome": "User sees all PolicyNFT tokens they hold with status and payout info",
      "tags": ["coverage", "policies", "wallet"],
      "steps": [
        {
          "order": 1,
          "screen": "coverage.list",
          "description": "User navigates to /coverage with wallet connected",
          "pipelineRef": "forge-contracts",
          "checks": [
            "usePoliciesByHolder(address) fetches token IDs from PolicyNFT"
          ]
        },
        {
          "order": 2,
          "screen": "coverage.list",
          "description": "Each policy card shows pool name, status badge, premium, coverage, expiry",
          "pipelineRef": "forge-contracts",
          "checks": [
            "Filter by status works (all/active/settled/expired/cancelled)"
          ]
        }
      ]
    },
    {
      "id": "czusd-conversion",
      "name": "User Converts USD to CZUSD",
      "trigger": "user_action",
      "priority": "high",
      "module": "acquire",
      "outcome": "User receives CZUSD tokens after Stripe payment and server-side mint",
      "tags": ["czusd", "stripe", "payment", "mint"],
      "steps": [
        {
          "order": 1,
          "screen": "acquire.flow",
          "description": "User selects 'Pay with Card' in payment step",
          "checks": [
            "Stripe payment form shown",
            "Amount pre-filled from pool premium"
          ]
        },
        {
          "order": 2,
          "endpoint": "acquire.stripe-payment",
          "description": "POST /api/stripe-payment creates PaymentIntent, returns clientSecret",
          "pipelineRef": "api-endpoints",
          "checks": ["clientSecret returned", "Amount in cents correct"]
        },
        {
          "order": 3,
          "endpoint": "acquire.stripe-webhook",
          "description": "Stripe sends payment_intent.succeeded webhook, server mints CZUSD to user",
          "pipelineRef": "forge-contracts",
          "checks": ["Signature verified", "CZUSD minted on-chain"]
        }
      ]
    }
  ],
  "infrastructure": {
    "blockchain": [
      {
        "name": "Avalanche Fuji",
        "chainId": 43113,
        "rpc": "env:NEXT_PUBLIC_AVAX_FUJI_RPC_URL",
        "contracts": [
