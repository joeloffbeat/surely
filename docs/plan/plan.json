{
  "app": {
    "name": "Surely",
    "description": "Parametric insurance protocol on Chainlink CRE. Insurance pools with custom trigger conditions, multi-source data verification, AI adjudication, and instant on-chain payouts. No claims, no adjusters, no waiting.",
    "version": "0.1.0",
    "techStack": {
      "framework": "Next.js 15 (App Router)",
      "language": "TypeScript",
      "auth": "Thirdweb Connect (email, social, WalletConnect)",
      "ui": "Tailwind CSS + shadcn/ui",
      "stateManagement": "React Query + React useState",
      "ai": "Claude Service (app-level AI advisor)",
      "blockchain": "Foundry (Solidity ^0.8.24), Thirdweb SDK v5, viem",
      "payments": "Stripe + CZUSD (ERC-20 stablecoin)",
      "testing": "Foundry (contracts), Playwright (e2e)"
    }
  },
  "modules": [
    {
      "id": "pools",
      "name": "Insurance Pools",
      "description": "Browse all insurance pools with grid/table view, search, and type filtering",
      "color": "#6366f1",
