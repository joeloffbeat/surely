    {
      "id": "cre",
      "name": "CRE Workflows",
      "description": "Chainlink Runtime Environment workflows: trigger-monitoring, eligibility-kyc, settlement, payment-fiat",
      "color": "#ef4444",
      "icon": "Zap",
      "counts": {
        "screens": 0,
        "endpoints": 0,
        "tables": 4,
